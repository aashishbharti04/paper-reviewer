{
  "order": [
    "groq",
    "ollama",
    "openrouter"
  ],
  "auto_fallback": true,
  "providers": {
    "groq": {
      "enabled": true,
      "model": "llama-3.3-70b-versatile",
      "api_keys": [
        "YOUR_GROQ_API_KEY_HERE"
      ]
    },
    "ollama": {
      "enabled": false,
      "model": "llama3.1",
      "base_url": "http://localhost:11434"
    },
    "openrouter": {
      "enabled": true,
      "model": "meta-llama/llama-3.1-70b-instruct:free",
      "api_keys": [
        "YOUR_OPENROUTER_API_KEY_HERE"
      ]
    }
  }
}
